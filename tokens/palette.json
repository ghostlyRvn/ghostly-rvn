{
  "meta": {
    "name": "Ghostly RVN",
    "version": "0.2.0",
    "description": "A 90s-anime science-fiction aesthetic — futurism and retro-futurism first, with a cyberpunk undercurrent. Cel-painted dusk skylines, neon haze and chrome, rendered in soft-but-saturated color.",
    "influences": [
      "Neon Genesis Evangelion",
      "Akira",
      "Ghost in the Shell",
      "Cowboy Bebop",
      "Sailor Moon",
      "Nier: Automata",
      "Stellar Blade",
      "P.N.03",
      "Starfield",
      "No Man's Sky"
    ],
    "author": "ghostlyrvn",
    "defaultTheme": "spectre",
    "themes": [
      { "slug": "spectre", "label": "Spectre", "appearance": "dark",  "blurb": "cool dusk-dark; cyan/violet over a blue-black void" },
      { "slug": "halo",    "label": "Halo",    "appearance": "light", "blurb": "cool daylight; ink on cool mist with saturated accents" },
      { "slug": "ember",   "label": "Ember",   "appearance": "light", "blurb": "warm parchment; amber-led with a cool teal counterpoint" }
    ]
  },

