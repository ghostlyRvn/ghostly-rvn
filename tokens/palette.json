  "typography": {
    "font.mono":    "\"Monaspace Neon\", ui-monospace, \"SFMono-Regular\", monospace",
    "font.display": "\"Monaspace Krypton\", \"Monaspace Neon\", ui-monospace, monospace",
    "font.sans":    "\"Monaspace Argon\", ui-monospace, monospace",
    "font.slab":    "\"Monaspace Xenon\", \"Monaspace Neon\", ui-monospace, monospace",
    "font.hand":    "\"Monaspace Radon\", \"Monaspace Neon\", ui-monospace, monospace"
  },

  "fonts": [
    { "family": "Monaspace Neon",    "slug": "neon",    "role": "mono / code / terminal" },
    { "family": "Monaspace Krypton", "slug": "krypton", "role": "display / HUD headings" },
    { "family": "Monaspace Argon",   "slug": "argon",   "role": "sans / UI / body" },
    { "family": "Monaspace Xenon",   "slug": "xenon",   "role": "slab / quotes / emphasis" },
    { "family": "Monaspace Radon",   "slug": "radon",   "role": "hand / accents" }
  ],

  "radius": {
