        "accent.secondary":      "violet.500",
        "accent.tertiary":       "blue.500",
        "accent.hot":            "magenta.500",

        "border.default": "ink.600",
        "border.muted":   "ink.700",
        "border.accent":  "cyan.600",

        "signal.success": "green.500",
        "signal.warning": "amber.500",
