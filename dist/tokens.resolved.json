{
  "meta": {
    "name": "Ghostly RVN",
    "theme": "Spectre",
    "version": "0.1.0",
    "description": "A 90s-anime cyberpunk aesthetic. Cool-anchored: cyan, teal and violet glowing over a blue-black void, cut with hot HUD accents (magenta, amber, red) for that anime warning-light pop.",
    "influences": [
      "Neon Genesis Evangelion",
      "Akira",
      "Ghost in the Shell",
      "Cowboy Bebop",
      "Nier: Automata",
      "Stellar Blade",
      "P.N.03",
      "Starfield / No Man's Sky futurism"
    ],
    "author": "ghostlyrvn"
  },
  "semantic": {
    "bg.void": "#070a10",
    "bg.deep": "#0b0f17",
    "bg.base": "#0f1420",
    "bg.surface": "#141b2b",
