      "Neon Genesis Evangelion",
      "Akira",
      "Ghost in the Shell",
      "Cowboy Bebop",
      "Sailor Moon",
      "Nier: Automata",
      "Stellar Blade",
      "P.N.03",
      "Starfield",
      "No Man's Sky"
    ],
